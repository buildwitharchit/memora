# Required
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: LLM Models
PRIMARY_MODEL=google/gemma-3-12b-it
UTILITY_MODEL=google/gemma-3-12b-it

# Optional: Memory Tuning
SENSORY_MAX_MESSAGES=8
COMPRESSION_BATCH_SIZE=4
SEMANTIC_TOP_K=3
EPISODIC_SNIPPET_SIZE=5

# Optional: Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: Storage
STORE_PATH=./store

# --- Docker ---
# Build: docker build -t memora .
# Run:   docker run -p 8501:8501 -e OPENROUTER_API_KEY=sk-or-... memora
# Or:    OPENROUTER_API_KEY=sk-or-... docker-compose up
